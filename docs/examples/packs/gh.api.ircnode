{
  "typeId": "gh.api",
  "title": "GitHub: API",
  "subtitle": "community",
  "icon": "🛰️",
  "category": "Action",
  "description": "Calls the GitHub REST/GraphQL API via gh api, e.g. endpoint = repos/owner/name.",
  "inputs": [
    {
      "name": "",
      "kind": "Exec"
    },
    {
      "name": "endpoint",
      "kind": "Text"
    }
  ],
  "outputs": [
    {
      "name": "then",
      "kind": "Exec"
    },
    {
      "name": "json",
      "kind": "Text"
    }
  ],
  "params": [
    {
      "key": "method",
      "label": "Method",
      "type": "Choice",
      "default": "GET",
      "choices": [
        "GET",
        "POST",
        "PATCH",
        "DELETE"
      ]
    }
  ],
  "language": "python",
  "timeout": 20,
  "code": "import os,subprocess\ncmd=['gh','api',os.environ.get('ENDPOINT',''),'-X',os.environ.get('METHOD','GET')]\ntry:\n    r=subprocess.run(cmd,capture_output=True,text=True,timeout=18)\n    print((r.stdout or r.stderr).strip()[:6000])\nexcept Exception as e:\n    print('ERROR: '+str(e))\n",
  "iconImage": ""
}
