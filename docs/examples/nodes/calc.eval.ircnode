{
  "typeId": "calc.eval",
  "title": "Calculator",
  "subtitle": "community",
  "icon": "🧮",
  "category": "Data",
  "description": "Safely evaluates an arithmetic expression (+ - * / % ** // and parens).",
  "inputs": [
    {
      "name": "",
      "kind": "Exec"
    },
    {
      "name": "expr",
      "kind": "Text"
    }
  ],
  "outputs": [
    {
      "name": "then",
      "kind": "Exec"
    },
    {
      "name": "result",
      "kind": "Text"
    }
  ],
  "params": [],
  "language": "python",
  "timeout": 12,
  "code": "\nimport os,ast,operator as op\nops={ast.Add:op.add,ast.Sub:op.sub,ast.Mult:op.mul,ast.Div:op.truediv,ast.Mod:op.mod,ast.Pow:op.pow,ast.FloorDiv:op.floordiv,ast.USub:op.neg,ast.UAdd:op.pos}\ndef ev(n):\n    if isinstance(n,ast.Constant) and isinstance(n.value,(int,float)): return n.value\n    if isinstance(n,ast.BinOp):\n        if isinstance(n.op,ast.Pow) and ev(n.right)>256: raise ValueError('exponent too large')\n        return ops[type(n.op)](ev(n.left),ev(n.right))\n    if isinstance(n,ast.UnaryOp): return ops[type(n.op)](ev(n.operand))\n    raise ValueError('bad')\ne=(os.environ.get('EXPR') or os.environ.get('ARGS') or '').strip()\ntry:\n    r=ev(ast.parse(e,mode='eval').body); print(('%g'%r) if isinstance(r,float) else str(r))\nexcept Exception: print('cannot evaluate: '+e)\n"
}
