<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net8.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <RollForward>Major</RollForward>
    <AssemblyName>Ircuitry</AssemblyName>
    <RootNamespace>Ircuitry</RootNamespace>
    <ApplicationIcon>../../assets/icons/ircuitry.ico</ApplicationIcon>
  </PropertyGroup>

  <ItemGroup>
    <!-- MonoGame DesktopGL sets the window/taskbar icon from an embedded "{AssemblyName}.Icon.bmp" -->
    <EmbeddedResource Include="Icon.bmp" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="FontStashSharp.MonoGame" Version="1.5.6" />
    <PackageReference Include="MonoGame.Framework.DesktopGL" Version="3.8.4.1" />
    <PackageReference Include="Microsoft.Data.Sqlite" Version="8.0.10" />
    <PackageReference Include="Tmds.DBus" Version="0.92.0" />
  </ItemGroup>

  <ItemGroup>
    <None Include="../../assets/**/*">
      <Link>assets/%(RecursiveDir)%(Filename)%(Extension)</Link>
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
  </ItemGroup>

</Project>
