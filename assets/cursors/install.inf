[Version]
signature="$CHICAGO$"

[DefaultInstall]
CopyFiles = Scheme.Cur
AddReg = Scheme.Reg

[DestinationDirs]
Scheme.Cur = 25,Cursors

[Scheme.Cur]
EWResize.cur
Alternate.cur
EWResize.cur
Link.cur
Move.cur
Help.cur
Move.cur
NEResize.cur
NEResize.cur
Normal.cur
NSResize.cur
NSResize.cur
NotAllowed.cur
NotAllowed.cur
NWResize.cur
NWResize.cur
Text.cur
Precision.cur
Wait_32-48-64.ani
AppStarting_32-48-64.ani

[Scheme.Reg]
HKCU,"Control Panel\Cursors","SizeWE",,"%25%\Cursors\EWResize.cur"
HKCU,"Control Panel\Cursors","UpArrow",,"%25%\Cursors\Alternate.cur"
HKCU,"Control Panel\Cursors","SizeWE",,"%25%\Cursors\EWResize.cur"
HKCU,"Control Panel\Cursors","Hand",,"%25%\Cursors\Link.cur"
HKCU,"Control Panel\Cursors","SizeAll",,"%25%\Cursors\Move.cur"
HKCU,"Control Panel\Cursors","Help",,"%25%\Cursors\Help.cur"
HKCU,"Control Panel\Cursors","SizeAll",,"%25%\Cursors\Move.cur"
HKCU,"Control Panel\Cursors","SizeNESW",,"%25%\Cursors\NEResize.cur"
HKCU,"Control Panel\Cursors","SizeNESW",,"%25%\Cursors\NEResize.cur"
HKCU,"Control Panel\Cursors","Arrow",,"%25%\Cursors\Normal.cur"
HKCU,"Control Panel\Cursors","SizeNS",,"%25%\Cursors\NSResize.cur"
HKCU,"Control Panel\Cursors","SizeNS",,"%25%\Cursors\NSResize.cur"
HKCU,"Control Panel\Cursors","No",,"%25%\Cursors\NotAllowed.cur"
HKCU,"Control Panel\Cursors","No",,"%25%\Cursors\NotAllowed.cur"
HKCU,"Control Panel\Cursors","SizeNWSE",,"%25%\Cursors\NWResize.cur"
HKCU,"Control Panel\Cursors","SizeNWSE",,"%25%\Cursors\NWResize.cur"
HKCU,"Control Panel\Cursors","IBeam",,"%25%\Cursors\Text.cur"
HKCU,"Control Panel\Cursors","Cross",,"%25%\Cursors\Precision.cur"
HKCU,"Control Panel\Cursors","Wait",,"%25%\Cursors\Wait_32-48-64.ani"
HKCU,"Control Panel\Cursors","AppStarting",,"%25%\Cursors\AppStarting_32-48-64.ani"
; Set scheme name
HKCU,"Control Panel\Cursors","(Default)",,"Future Cursor"
HKCU,"Control Panel\Cursors\Schemes","Future Cursor",,""