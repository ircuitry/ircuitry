{
 "format": "ircuitry.plugin.v1",
 "name": "AI Assistant",
 "version": "1.3.0",
 "icon": "robot",
 "description": "Chat with an AI in a side panel. It can view and edit any of your workflows when you ask, and shows live what it's doing. Click the gear to set your API base URL, model, and key (picked from your saved secrets). Works with any OpenAI-compatible API.",
 "permissions": [ "edit-graph", "network", "panel", "settings" ],
 "nodes": [
  { "id": "s",   "type": "app.start", "x": 0, "y": 0, "params": {} },
  { "id": "pn",  "type": "app.panel", "x": 200, "y": 0, "params": { "id": "ai", "title": "AI Assistant", "icon": "robot", "dock": "right" } },
  { "id": "sf1", "type": "app.settings", "x": 400, "y": 0, "params": { "key": "ai_baseurl", "label": "API base URL", "type": "text", "placeholder": "https://api.openai.com/v1" } },
  { "id": "sf2", "type": "app.settings", "x": 600, "y": 0, "params": { "key": "ai_model", "label": "Model", "type": "text", "placeholder": "gpt-4o-mini" } },
  { "id": "sf3", "type": "app.settings", "x": 800, "y": 0, "params": { "key": "ai_key", "label": "API key", "type": "secret", "placeholder": "" } },
  { "id": "dv1", "type": "data.setvar", "x": 1000, "y": 0, "params": { "name": "ai_baseurl", "mode": "default", "value": "https://api.openai.com/v1" } },
  { "id": "dv2", "type": "data.setvar", "x": 1200, "y": 0, "params": { "name": "ai_model", "mode": "default", "value": "gpt-4o-mini" } },
  { "id": "dv3", "type": "data.setvar", "x": 1400, "y": 0, "params": { "name": "chat", "mode": "default", "value": "Hi! Ask me anything, or tell me to look at or edit one of your workflows.\n\n" } },

  { "id": "ob",   "type": "app.on", "x": 0, "y": 220, "params": { "event": "panel", "id": "ai" } },
  { "id": "moh",  "type": "data.math", "x": 160, "y": 360, "params": { "op": "-", "a": "{app_panel_h}", "b": "88" } },
  { "id": "svoh", "type": "data.setvar", "x": 160, "y": 220, "params": { "name": "out_h", "mode": "set" } },
  { "id": "miy",  "type": "data.math", "x": 320, "y": 360, "params": { "op": "-", "a": "{app_panel_h}", "b": "34" } },
  { "id": "sviy", "type": "data.setvar", "x": 320, "y": 220, "params": { "name": "in_y", "mode": "set" } },
  { "id": "msy",  "type": "data.math", "x": 480, "y": 360, "params": { "op": "-", "a": "{app_panel_h}", "b": "52" } },
  { "id": "svsy", "type": "data.setvar", "x": 480, "y": 220, "params": { "name": "status_y", "mode": "set" } },
  { "id": "mw",   "type": "data.math", "x": 640, "y": 360, "params": { "op": "-", "a": "{app_panel_w}", "b": "8" } },
  { "id": "svw",  "type": "data.setvar", "x": 640, "y": 220, "params": { "name": "w_in", "mode": "set" } },
  { "id": "w",    "type": "ui.window", "x": 800, "y": 220, "params": { "window": "ai", "title": "AI Assistant", "bg": "#F4EFFB" } },
  { "id": "title","type": "ui.text", "x": 960, "y": 220, "params": { "window": "ai", "id": "title", "x": "6", "y": "5", "text": "AI assistant", "size": "14", "font": "display", "color": "#6B5BAE" } },
  { "id": "gear", "type": "ui.button", "x": 1120, "y": 220, "params": { "window": "ai", "id": "gear", "x": "232", "y": "4", "w": "24", "h": "22", "text": "gear", "icon": "true", "color": "#E9E2F4", "textColor": "#6B5BAE", "radius": "7" } },
  { "id": "out",  "type": "ui.input", "x": 1280, "y": 220, "params": { "window": "ai", "id": "out", "x": "4", "y": "32", "w": "{w_in}", "h": "{out_h}", "text": "{chat}", "textColor": "#36314A", "font": "sans", "size": "13", "multiline": "true", "readonly": "true" } },
  { "id": "stat", "type": "ui.text", "x": 1440, "y": 220, "params": { "window": "ai", "id": "status_line", "x": "8", "y": "{status_y}", "text": "", "size": "11", "font": "sans", "color": "#8C7FB8" } },
  { "id": "cmd",  "type": "ui.input", "x": 1600, "y": 220, "params": { "window": "ai", "id": "cmd", "x": "4", "y": "{in_y}", "w": "{w_in}", "h": "30", "text": "", "color": "#B9AED6", "textColor": "#36314A", "font": "sans", "size": "13", "multiline": "false", "placeholder": "Message the AI and press Enter" } },

  { "id": "og",  "type": "ui.on", "x": 0, "y": 480, "params": { "window": "ai", "event": "click", "id": "gear" } },
  { "id": "opn", "type": "app.opensettings", "x": 200, "y": 480, "params": {} },

  { "id": "os",    "type": "ui.on", "x": 0, "y": 660, "params": { "window": "ai", "event": "submit", "id": "cmd" } },
  { "id": "echo",  "type": "data.setvar", "x": 160, "y": 660, "params": { "name": "chat", "mode": "set", "value": "{chat}You: {ui_value}\n\n" } },
  { "id": "ref1",  "type": "ui.input", "x": 320, "y": 660, "params": { "window": "ai", "id": "out", "x": "4", "y": "32", "w": "{w_in}", "h": "{out_h}", "text": "{chat}", "textColor": "#36314A", "font": "sans", "size": "13", "multiline": "true", "readonly": "true" } },
  { "id": "clr",   "type": "ui.input", "x": 480, "y": 660, "params": { "window": "ai", "id": "cmd", "x": "4", "y": "{in_y}", "w": "{w_in}", "h": "30", "text": "", "color": "#B9AED6", "textColor": "#36314A", "font": "sans", "size": "13", "multiline": "false", "placeholder": "Message the AI and press Enter" } },
  { "id": "memu",  "type": "ai.memory", "x": 640, "y": 660, "params": { "session": "ai", "mode": "remember", "role": "user", "text": "{ui_value}", "max": "16" } },
  { "id": "recall","type": "ai.memory", "x": 800, "y": 660, "params": { "session": "ai", "mode": "recall", "max": "16" } },
  { "id": "ai",    "type": "ai.reply", "x": 960, "y": 660, "params": { "baseUrl": "{ai_baseurl}", "model": "{ai_model}", "apiKey": "{ai_key}", "system": "You are a helpful assistant embedded in ircuitry, a visual node-graph bot builder. When the user asks about or wants to change their workflows (bots), use your tools to read and edit them. Be concise but finish your answer; prefer short paragraphs over long lists.", "prompt": "{ui_value}", "maxTokens": "1500", "timeout": "90", "maxSteps": "16", "statusWindow": "ai", "statusElement": "status_line" } },
  { "id": "editor","type": "ai.editor", "x": 960, "y": 840, "params": { "bot": "", "mode": "edit" } },
  { "id": "svr",   "type": "data.setvar", "x": 1120, "y": 660, "params": { "name": "reply_var", "mode": "set" } },
  { "id": "mema",  "type": "ai.memory", "x": 1280, "y": 660, "params": { "session": "ai", "mode": "remember", "role": "assistant", "max": "16" } },
  { "id": "show",  "type": "data.setvar", "x": 1440, "y": 660, "params": { "name": "chat", "mode": "set", "value": "{chat}AI: {reply_var}{ai_error}\n{ai_tools_used}\n" } },
  { "id": "ref2",  "type": "ui.input", "x": 1600, "y": 660, "params": { "window": "ai", "id": "out", "x": "4", "y": "32", "w": "{w_in}", "h": "{out_h}", "text": "{chat}", "textColor": "#36314A", "font": "sans", "size": "13", "multiline": "true", "readonly": "true" } }
 ],
 "connections": [
  { "from": "s",   "fromPin": 0, "to": "pn",  "toPin": 0 },
  { "from": "pn",  "fromPin": 0, "to": "sf1", "toPin": 0 },
  { "from": "sf1", "fromPin": 0, "to": "sf2", "toPin": 0 },
  { "from": "sf2", "fromPin": 0, "to": "sf3", "toPin": 0 },
  { "from": "sf3", "fromPin": 0, "to": "dv1", "toPin": 0 },
  { "from": "dv1", "fromPin": 0, "to": "dv2", "toPin": 0 },
  { "from": "dv2", "fromPin": 0, "to": "dv3", "toPin": 0 },

  { "from": "ob",   "fromPin": 0, "to": "svoh", "toPin": 0 },
  { "from": "moh",  "fromPin": 0, "to": "svoh", "toPin": 1 },
  { "from": "svoh", "fromPin": 0, "to": "sviy", "toPin": 0 },
  { "from": "miy",  "fromPin": 0, "to": "sviy", "toPin": 1 },
  { "from": "sviy", "fromPin": 0, "to": "svsy", "toPin": 0 },
  { "from": "msy",  "fromPin": 0, "to": "svsy", "toPin": 1 },
  { "from": "svsy", "fromPin": 0, "to": "svw",  "toPin": 0 },
  { "from": "mw",   "fromPin": 0, "to": "svw",  "toPin": 1 },
  { "from": "svw",  "fromPin": 0, "to": "w",     "toPin": 0 },
  { "from": "w",    "fromPin": 0, "to": "title", "toPin": 0 },
  { "from": "title","fromPin": 0, "to": "gear",  "toPin": 0 },
  { "from": "gear", "fromPin": 0, "to": "out",   "toPin": 0 },
  { "from": "out",  "fromPin": 0, "to": "stat",  "toPin": 0 },
  { "from": "stat", "fromPin": 0, "to": "cmd",   "toPin": 0 },

  { "from": "og",  "fromPin": 0, "to": "opn", "toPin": 0 },

  { "from": "os",     "fromPin": 0, "to": "echo",   "toPin": 0 },
  { "from": "echo",   "fromPin": 0, "to": "ref1",   "toPin": 0 },
  { "from": "ref1",   "fromPin": 0, "to": "clr",    "toPin": 0 },
  { "from": "clr",    "fromPin": 0, "to": "memu",   "toPin": 0 },
  { "from": "memu",   "fromPin": 0, "to": "recall", "toPin": 0 },
  { "from": "recall", "fromPin": 0, "to": "ai",     "toPin": 0 },
  { "from": "recall", "fromPin": 1, "to": "ai",     "toPin": 1 },
  { "from": "editor", "fromPin": 0, "to": "ai",     "toPin": 2 },
  { "from": "ai",     "fromPin": 0, "to": "svr",    "toPin": 0 },
  { "from": "ai",     "fromPin": 1, "to": "svr",    "toPin": 1 },
  { "from": "svr",    "fromPin": 0, "to": "mema",   "toPin": 0 },
  { "from": "ai",     "fromPin": 1, "to": "mema",   "toPin": 1 },
  { "from": "mema",   "fromPin": 0, "to": "show",   "toPin": 0 },
  { "from": "show",   "fromPin": 0, "to": "ref2",   "toPin": 0 }
 ]
}
